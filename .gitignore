OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE
SOFTWARE."""

    # .gitignore Content
    # Essential for 2026 security to exclude secrets and build artifacts.
    gitignore_content = """# Dependencies
node_modules/
jspm_packages/
typings/

# Secrets & Environment
.env
.env.local
.env.production
*.key
*.pem

# Build Artifacts (Hardhat/Foundry)
artifacts/
cache/
typechain/
typechain-types/
out/

# Testing & Coverage
coverage/
coverage.json
.nyc_output

# Python
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
.env/

# IDE & OS
.vscode/
.idea/
.DS_Store
*.swp"""

    # 2. Create Directory Structure
    folders = ['contracts', 'scripts']
    for folder in folders:
        if not os.path.exists(folder):
            os.makedirs(folder)
            print(f"Created directory: {folder}")

    # 3. Write Files
    files = {
        "contracts/Qubicoin.sol": solidity_contract,
        "README.md": readme_content,
        "scripts/deploy.py": deploy_script,
        "LICENSE": license_text,
        ".gitignore": gitignore_content
    }

    for path, content in files.items():
        with open(path, "w") as f:
            f.write(content)
        print(f"Created file: {path}")

    # 4. Initialize Git Repository
    try:
        subprocess.run(["git", "init"], check=True)
        print("Initialized empty Git repository.")
        
        # Optional: Initial add and commit
        # subprocess.run(["git", "add", "."], check=True)
        # subprocess.run(["git", "commit", "-m", "Initial commit: Qubicoin Project Setup"], check=True)
        # print("Created initial commit.")
    except Exception as e:
        print(f"Warning: Git initialization failed. Is git installed? Error: {e}")

    print("\nProject Initialization Complete!")
    print("Next steps: Compile your contract and update the ABI in scripts/deploy.py.")
if __name__ == "__main__":
    create_project()


